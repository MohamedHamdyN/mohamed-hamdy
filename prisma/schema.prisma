// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NextAuth Auth Tables
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  password      String?
  image         String?
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Portfolio Data Models
model Profile {
  id                   String   @id @default(cuid())
  name                 String
  title                String
  title2               String?
  email                String
  phone                String?
  location             String?
  bio                  String   @db.Text
  shortBio             String
  longBio              String   @db.Text
  logo                 String
  favicon              String
  avatar               String
  defaultProjectImage  String
  defaultClientLogo    String
  defaultPlatformLogo  String
  ogImage              String
  resumeUrl            String
  calendlyUrl          String?
  socialLinks          SocialLink[]
  stats                Stat[]
  certifications       Certification[]
  journeyEntries       JourneyEntry[]
  educationEntries     EducationEntry[]
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  
  @@map("profiles")
}

model SocialLink {
  id        String   @id @default(cuid())
  profileId String
  platform  String   // linkedin, github, twitter, instagram, datacamp, facebook, etc.
  url       String
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([profileId])
  @@index([isActive])
  @@map("social_links")
}

model Stat {
  id        String   @id @default(cuid())
  profileId String
  name      String
  value     String
  icon      String
  color     String
  enabled   Boolean  @default(true)
  order     Int      @default(0)
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([profileId])
  @@map("stats")
}

model Certification {
  id            String   @id @default(cuid())
  profileId     String
  title         String
  issuer        String
  date          String   // e.g., "2023"
  credentialUrl String
  description   String   @db.Text
  enabled       Boolean  @default(true)
  order         Int      @default(0)
  profile       Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([profileId])
  @@map("certifications")
}

model JourneyEntry {
  id        String   @id @default(cuid())
  profileId String
  year      String
  title     String
  description String
  details   String   @db.Text
  order     Int      @default(0)
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([profileId])
  @@map("journey_entries")
}

model EducationEntry {
  id        String   @id @default(cuid())
  profileId String
  year      String
  institution String
  degree    String
  details   String   @db.Text
  order     Int      @default(0)
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([profileId])
  @@map("education_entries")
}

model Project {
  id                String      @id @default(cuid())
  title             String
  description       String      @db.Text
  shortDescription  String
  slug              String      @unique
  categoryId        Int
  image             String?
  projectUrl        String?
  linkedinUrl       String?
  technologies      String[]    @default([])
  date              String      // e.g., "2023-05"
  featured          Boolean     @default(false)
  status            String      @default("published") // published, draft
  images            ProjectImage[]
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([status])
  @@index([featured])
  @@index([slug])
  @@map("projects")
}

model ProjectImage {
  id        String   @id @default(cuid())
  projectId String
  imageUrl  String
  caption   String?
  order     Int      @default(0)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@map("project_images")
}

model Skill {
  id        String   @id @default(cuid())
  name      String
  description String @db.Text
  icon      String
  color     String
  enabled   Boolean  @default(true)
  category  String?  // optional category grouping
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([enabled])
  @@map("skills")
}

model Client {
  id        String   @id @default(cuid())
  name      String
  logo      String
  testimonial String? @db.Text
  rating    Int      @default(5)
  website   String?
  lastProject String?
  enabled   Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([enabled])
  @@map("clients")
}

model Service {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  icon        String
  color       String
  features    String[] @default([])
  enabled     Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([enabled])
  @@map("services")
}

model SiteSettings {
  id                  String   @id @default(cuid())
  siteStatus          String   @default("active") // active, maintenance
  defaultLanguage     String   @default("en")
  enableLanguageToggle Boolean @default(false)
  
  // Home page sections visibility
  websiteEnabled      Boolean  @default(true)
  projectsPageEnabled Boolean  @default(true)
  servicesPageEnabled Boolean  @default(true)
  aboutPageEnabled    Boolean  @default(true)
  contactPageEnabled  Boolean  @default(true)
  resumePageEnabled   Boolean  @default(true)
  
  // Home sections
  projectsHomeEnabled Boolean  @default(true)
  servicesHomeEnabled Boolean  @default(true)
  aboutHomeEnabled    Boolean  @default(true)
  skillsEnabled       Boolean  @default(true)
  whyWorkWithMeEnabled Boolean @default(true)
  clientsEnabled      Boolean  @default(true)
  contactHomeEnabled  Boolean  @default(true)
  
  // Services page
  freelancePlatformsEnabled Boolean @default(true)
  paymentMethodsEnabled     Boolean @default(true)
  
  // Contact page
  contactFormEnabled  Boolean  @default(true)
  
  // Features
  calendlyFeatureEnabled Boolean @default(true)
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("site_settings")
}

// Project Categories (reference data)
model ProjectCategory {
  id   Int    @id
  name String @unique
  key  String @unique // dataVisualization, machineLeaning, etc.

  @@map("project_categories")
}
